# ═══════════════════════════════════════════════════════════════════════════════
# FloraPetFriend — Variables de entorno de PRODUCCIÓN (CubePath)
# Estas variables se configuran en el panel de CubePath, NO en este archivo.
# Este archivo es solo de referencia.
# ═══════════════════════════════════════════════════════════════════════════════

# ─── Supabase ─────────────────────────────────────────────────────────────────
# OPCIÓN A — Supabase Cloud (recomendado, gratuito en https://supabase.com):
#   NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
#
# OPCIÓN B — Self-hosted en CubePath (Kong gateway, NO el puerto de PostgreSQL):
#   NEXT_PUBLIC_SUPABASE_URL=http://fpf-supabase-kong:8000
#
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Ollama (LLaVA) ───────────────────────────────────────────────────────────
# En CubePath: nombre interno del contenedor de Ollama
OLLAMA_BASE_URL=http://fpf-ollama:11434
OLLAMA_MODEL=llava:13b

# ─── MinIO ────────────────────────────────────────────────────────────────────
# En CubePath: nombre interno del contenedor de MinIO
MINIO_ENDPOINT=fpf-minio
MINIO_PORT=9000
MINIO_ACCESS_KEY=fpf_admin
MINIO_SECRET_KEY=your-strong-minio-password
MINIO_BUCKET_PETS=pet-photos
MINIO_BUCKET_AVATARS=virtual-pets
MINIO_USE_SSL=false

# ─── n8n webhook ──────────────────────────────────────────────────────────────
# En CubePath: URL pública del subdominio de n8n
N8N_WEBHOOK_URL=https://n8n.florapetfriend.site/webhook
N8N_API_KEY=your-n8n-api-key

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://florapetfriend.site
NEXT_PUBLIC_APP_NAME=FloraPetFriend
NODE_ENV=production

# ─── Geo / Weather ────────────────────────────────────────────────────────────
OPENWEATHER_API_KEY=your-openweather-api-key
